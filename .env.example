# Mapbox public (pk.) token, used by the map section.
# Get one at https://account.mapbox.com/access-tokens/
# For deploys, set this in Netlify: Site configuration > Environment variables.
VITE_MAPBOX_TOKEN=

# ── AI chat (Netlify function /api/chat) ──
# All of these are server-side only (no VITE_ prefix: never shipped to the browser).
# Google Gemini API key — https://aistudio.google.com/apikey (free tier available).
GEMINI_API_KEY=
# Optional, defaults to gemini-3.1-flash-lite (higher free-tier rate limits;
# each chat message costs 2+ Gemini requests because of the query_concerts tool).
# NB: the whole gemini-2.5 family is deprecated (shutdown Oct 2026) — don't use it here.
GEMINI_MODEL=
# Upstash Redis (rate limiting + chat transcript log) — https://console.upstash.com.
# If missing, the function falls back to a best-effort in-memory limiter (resets
# on cold start) and conversations are NOT persisted.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional rate-limit knobs: requests/minute/IP, requests/day/IP, requests/day global.
# Defaults: 8 / 40 / 200 (the global cap keeps a free Gemini key under its daily quota).
CHAT_RPM_PER_IP=
CHAT_RPD_PER_IP=
CHAT_RPD_GLOBAL=
# How long chat transcripts stay in Redis (keys `concerti:chat:log:<threadId>`,
# index `concerti:chat:log:index`). Optional, defaults to 90 days.
CHAT_LOG_TTL_DAYS=
