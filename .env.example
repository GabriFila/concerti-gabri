# Mapbox public (pk.) token, used by the map section.
# Get one at https://account.mapbox.com/access-tokens/
# For deploys, set this in Netlify: Site configuration > Environment variables.
VITE_MAPBOX_TOKEN=

# ── AI chat (Netlify function /api/chat) ──
# All of these are server-side only (no VITE_ prefix: never shipped to the browser).
# Google Gemini API key — https://aistudio.google.com/apikey (free tier available).
GEMINI_API_KEY=
# Optional, defaults to gemini-2.5-flash.
GEMINI_MODEL=
# Upstash Redis (rate limiting) — https://console.upstash.com. If missing, the
# function falls back to a best-effort in-memory limiter (resets on cold start).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional rate-limit knobs: requests/minute/IP, requests/day/IP, requests/day global.
# Defaults: 8 / 40 / 200 (the global cap keeps a free Gemini key under its daily quota).
CHAT_RPM_PER_IP=
CHAT_RPD_PER_IP=
CHAT_RPD_GLOBAL=
